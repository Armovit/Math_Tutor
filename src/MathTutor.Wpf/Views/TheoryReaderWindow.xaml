<Window x:Class="MathTutor.Wpf.Views.TheoryReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MathTutor.Wpf.Controls"
        Title="Режим чтения теории"
        Width="1320"
        Height="820"
        MinWidth="1120"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Background="{DynamicResource Brush.AppBackground}" Margin="24">
        <Border Style="{StaticResource ExperienceShell}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PremiumPanel}" Margin="0,0,22,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                            <Border Style="{StaticResource FeatureChip}" HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="Режим чтения" Foreground="White" FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Теория" Foreground="White" FontSize="34" FontWeight="Bold" />
                            <TextBlock Text="Выберите тему, раздел и материал. Всё остальное убрано, чтобы было удобно читать." Foreground="#E8FFFFFF" TextWrapping="Wrap" Margin="0,10,0,16" />
                            <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Обновить подборку" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" />
                        </StackPanel>

                        <TabControl ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}" ClipToBounds="True">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Header}" TextTrimming="CharacterEllipsis" MaxWidth="145" />
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Sections}" Margin="0,12,0,0" ClipToBounds="True">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,16">
                                                        <Border Style="{StaticResource FeatureChip}" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                            <TextBlock Text="{Binding Header}" Foreground="White" FontWeight="SemiBold" />
                                                        </Border>
                                                        <ListBox ItemsSource="{Binding Materials}"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 SelectedItem="{Binding DataContext.SelectedTheory, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Style="{StaticResource TestCard}" Margin="0,0,0,10" HorizontalAlignment="Stretch" ClipToBounds="True">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" Margin="0,6,0,0" MaxHeight="44" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource ReadingPaper}" Margin="0,0,0,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                    <Border Style="{StaticResource StatusPill}" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding SelectedTheory.Topic}" Foreground="{DynamicResource Brush.Primary}" FontWeight="Bold" />
                                    </Border>
                                    <Border Style="{StaticResource StatusPill}">
                                        <TextBlock Text="{Binding SelectedTheory.Section}" Foreground="{DynamicResource Brush.Info}" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedTheory.Title}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedTheory.Description}" FontSize="17" LineHeight="28" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ReadingPaper}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource AccentStrip}" Margin="0,0,24,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Материал для подготовки" Style="{StaticResource Text.Eyebrow}" />
                                    <controls:LatexTextBlock Text="{Binding SelectedTheory.TheoryContent}"
                                                             FontSize="18"
                                                             TextLineHeight="32"
                                                             FormulaFontSize="24"
                                                             Foreground="{DynamicResource Brush.TextPrimary}"
                                                             Margin="0,14,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
