<UserControl x:Class="MathTutor.Wpf.Views.StudentDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <ScrollViewer>
        <StackPanel>
            <Border Style="{StaticResource PremiumPanel}" Margin="0,0,0,22">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Личный прогресс" Foreground="#DFFFFFFF" FontWeight="Bold" FontSize="12" />
                        <TextBlock Text="Учебная траектория ученика" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,4,0,0" />
                        <TextBlock Text="Следите за результатами тестов, средним баллом и последними материалами." Foreground="#E8FFFFFF" FontSize="15" TextWrapping="Wrap" Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Выполнено заданий" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Progress.CompletedTasks}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Средний результат" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Progress.AverageScore, StringFormat={}{0}%}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Средний тест" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Progress.AverageTestPercent, StringFormat={}{0}%}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="Лучший тест" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Progress.BestTestPercent, StringFormat={}{0}%}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
            </UniformGrid>
            <Grid Margin="0,0,0,24" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource GlowCard}" Margin="0,0,16,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Сильные и слабые темы" Style="{StaticResource Text.H2}" Margin="0,0,0,6" />
                        <TextBlock Text="Диаграмма показывает средний результат по темам: самые слабые темы находятся слева." Style="{StaticResource Text.Body}" Margin="0,0,0,16" />
                        <lvc:CartesianChart Series="{Binding TopicSeries}" XAxes="{Binding TopicXAxes}" YAxes="{Binding TopicYAxes}" LegendPosition="Hidden" Height="220" MaxHeight="220" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource SurfaceCard}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Рекомендации" Style="{StaticResource Text.H2}" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding Progress.Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource InlinePanel}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Topic}" Style="{StaticResource Text.H3}" />
                                            <TextBlock Text="{Binding AveragePercent, StringFormat=Средний результат: {0}%}" Style="{StaticResource Text.Caption}" Margin="0,4,0,2" />
                                            <TextBlock Text="{Binding Message}" Style="{StaticResource Text.Body}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource GlowCard}"><StackPanel><TextBlock Text="Новые материалы" Style="{StaticResource Text.H2}" Margin="0,0,0,16"/><ItemsControl ItemsSource="{Binding RecentMaterials}"><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="0,14"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{StaticResource AccentStrip}" Height="46" Margin="0,0,14,0"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" Style="{StaticResource Text.H3}"/><TextBlock Text="{Binding Description}" Style="{StaticResource Text.Body}"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

