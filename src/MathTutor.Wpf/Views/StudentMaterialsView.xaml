<UserControl x:Class="MathTutor.Wpf.Views.StudentMaterialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MathTutor.Wpf.Controls"
             xmlns:conv="clr-namespace:MathTutor.Wpf.Converters">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" MinWidth="400" />
            <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource GlowCard}" Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBlock Text="Каталог тестов" Foreground="{DynamicResource Brush.Primary}" FontWeight="Bold" />
                    </Border>
                    <TextBlock Text="Темы и тесты" Style="{StaticResource Text.H2}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding CatalogSummary}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="13" Margin="0,0,0,14" />

                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Content="Найти"
                                Command="{Binding LoadCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="88"
                                Margin="8,0,0,0"
                                Padding="16,10" />
                        <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Название, тема или описание"
                                 VerticalContentAlignment="Center"
                                 MinHeight="40" />
                    </DockPanel>

                    <Expander Header="Фильтры" Margin="0,0,0,0" IsExpanded="False">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Тема" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                            <TextBox Text="{Binding TopicFilter, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Раздел" Style="{StaticResource Text.Caption}" Margin="0,10,0,6" />
                            <TextBox Text="{Binding SectionFilter, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Сложность" Style="{StaticResource Text.Caption}" Margin="0,10,0,6" />
                            <ComboBox ItemsSource="{Binding DifficultyFilters}" SelectedItem="{Binding DifficultyFilter}" />
                            <Button Content="Сбросить фильтры" Command="{Binding ResetFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,12,0,0" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <Grid Grid.Row="1" Visibility="{Binding HasCatalogItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="172" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" Text="Темы" Style="{StaticResource Text.Eyebrow}" Margin="4,0,0,8" />
                        <ListBox ItemsSource="{Binding Topics}"
                                 SelectedItem="{Binding SelectedTopic}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CatalogTopicItem}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" LineHeight="20" />
                                            <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <Border Grid.Column="2" Style="{StaticResource InlinePanel}" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="Тесты темы" Style="{StaticResource Text.Eyebrow}" />
                                <TextBlock Text="{Binding SelectedTopic.Name, TargetNullValue=Выберите тему}" Style="{StaticResource Text.H3}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding SelectedTopic.Meta}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,4,0,0"
                                           Visibility="{Binding HasSelectedTopic, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding SelectedTopic.Sections}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelectedTopic}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,16">
                                                <Border Style="{StaticResource CatalogSectionHeader}">
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Meta}" DockPanel.Dock="Right" Foreground="{DynamicResource Brush.Primary}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                                                    </DockPanel>
                                                </Border>
                                                <ListBox ItemsSource="{Binding Materials}"
                                                         SelectedItem="{Binding DataContext.SelectedMaterial, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         BorderThickness="0"
                                                         Background="Transparent">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource CatalogTestCard}">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" LineHeight="22" />
                                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                                        <Border Style="{StaticResource StatusPill}" Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding TaskCount, StringFormat={}{0} вопр.}" Foreground="{DynamicResource Brush.Primary}" FontWeight="SemiBold" FontSize="12" />
                                                                        </Border>
                                                                        <Border Style="{StaticResource StatusPill}" Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding Difficulty, Converter={StaticResource EnumDisplayConverter}}" Foreground="{DynamicResource Brush.Info}" FontWeight="SemiBold" FontSize="12" />
                                                                        </Border>
                                                                        <Border Style="{StaticResource StatusPill}">
                                                                            <TextBlock Text="{Binding Section}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Body}" TextWrapping="Wrap" MaxHeight="48" Margin="0,10,0,0" Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="Выберите тему слева, затем тест из списка."
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="13"
                                       Visibility="{Binding HasSelectedTopic, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        </DockPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Style="{StaticResource InlinePanel}"
                        Padding="24"
                        Visibility="{Binding HasCatalogItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Ничего не найдено" Style="{StaticResource Text.H3}" HorizontalAlignment="Center" />
                        <TextBlock Text="Измените поиск или сбросьте фильтры." Style="{StaticResource Text.Body}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,16" />
                        <Button Content="Сбросить фильтры" Command="{Binding ResetFiltersCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource PremiumPanel}" Margin="0,0,0,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource FeatureChip}" Margin="0,0,8,0">
                                <TextBlock Text="{Binding SelectedMaterial.Topic}" Foreground="White" FontWeight="Bold" FontSize="12" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedMaterial.Title}" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedMaterial.Description}" Foreground="#E8FFFFFF" FontSize="15" TextWrapping="Wrap" Margin="0,10,0,14" />
                        <controls:LatexTextBlock Text="{Binding SelectedMaterial.TheoryContent}" Foreground="#DFFFFFFF" FontSize="13" TextLineHeight="21" FormulaFontSize="18" />
                        <Border Style="{StaticResource FloatingActionPanel}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="В отдельном окне можно менять тему и тест без возврата назад." Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <Button Content="Открыть отдельное окно решения" Click="OpenSolver_Click" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" MinHeight="62" FontSize="16" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceCard}" Visibility="{Binding IsPracticeMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Задания" Style="{StaticResource Text.H2}" Margin="0,0,0,12" />
                        <ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" DisplayMemberPath="Title" MinHeight="120" MaxHeight="220" Margin="0,0,0,16" />
                        <controls:LatexTextBlock Text="{Binding SelectedTask.Question}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="14" TextLineHeight="22" FormulaFontSize="20" />
                        <DockPanel Margin="0,12,0,12">
                            <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenPracticeLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                            <TextBox x:Name="PracticeAnswerTextBox" Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                        <Button Content="Отправить решение" Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlowCard}" Visibility="{Binding IsSelectedMaterialTest, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Выбранный тест" Style="{StaticResource Text.Eyebrow}" />
                                <TextBlock Text="Готовы начать?" Style="{StaticResource Text.H2}" Margin="0,3,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border Style="{StaticResource StatusPill}" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} заданий}" Foreground="{DynamicResource Brush.Primary}" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Style="{StaticResource StatusPill}">
                                        <TextBlock Text="{Binding TestMaxScore, StringFormat=до {0} баллов}" Foreground="{DynamicResource Brush.Info}" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Начать тест" Command="{Binding StartTestCommand}" Style="{StaticResource PrimaryButton}" Visibility="{Binding CanStartTest, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                        <StackPanel Visibility="{Binding TestStarted, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Style="{StaticResource InlinePanel}" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource AccentStrip}" Margin="0,0,18,0" />
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Margin="0,0,0,14">
                                            <TextBlock Text="{Binding QuestionProgressText}" Foreground="{DynamicResource Brush.Primary}" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="{Binding CurrentTask.Title}" Style="{StaticResource Text.H2}" Margin="0,0,0,8" />
                                        <controls:LatexTextBlock Text="{Binding CurrentTask.Question}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="14" TextLineHeight="22" FormulaFontSize="20" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DockPanel Visibility="{Binding IsTextAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenTestLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                                <TextBox x:Name="TestAnswerTextBox" Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <ListBox ItemsSource="{Binding AnswerOptions}" SelectedItem="{Binding SelectedAnswerOption}" Visibility="{Binding IsSingleChoiceAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <controls:LatexTextBlock Text="{Binding Text}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="14" TextLineHeight="22" FormulaFontSize="19" Margin="8" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ItemsControl ItemsSource="{Binding AnswerOptions}" Visibility="{Binding IsMultipleChoiceAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4">
                                            <controls:LatexTextBlock Text="{Binding Text}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="14" TextLineHeight="22" FormulaFontSize="19" />
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Назад" Command="{Binding PreviousQuestionCommand}" Style="{StaticResource SecondaryButton}" IsEnabled="{Binding CanGoPrevious}" />
                                <Button Content="Далее" Command="{Binding NextQuestionCommand}" Style="{StaticResource SecondaryButton}" IsEnabled="{Binding CanGoNext}" Margin="8,0,0,0" />
                                <Button Content="Завершить тест" Command="{Binding FinishTestCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Success}" Margin="4,12,0,0" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Brush.Danger}" Margin="4,4,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
