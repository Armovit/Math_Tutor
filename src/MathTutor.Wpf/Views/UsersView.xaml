<UserControl x:Class="MathTutor.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource GlowCard}" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="Администрирование" Foreground="{DynamicResource Brush.Primary}" FontWeight="Bold" />
                        </Border>
                        <TextBlock Text="Ученики и пользователи" Style="{StaticResource Text.H2}" />
                        <TextBlock Text="{Binding UsersSummary}" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Найти" Command="{Binding LoadCommand}" Style="{StaticResource PrimaryButton}" MinWidth="120" />
                        <Button Content="Сбросить" Command="{Binding ResetFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Поиск" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Имя, фамилия или email"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Кого показать" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding RoleFilters}" SelectedItem="{Binding SelectedRoleFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Статус" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Сортировка" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}" />
                    </StackPanel>

                    <CheckBox Grid.Column="8"
                              Content="По убыванию"
                              IsChecked="{Binding SortDescending}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,12" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SurfaceCard}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Список пользователей" Style="{StaticResource Text.H2}" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Border Style="{StaticResource StatusPill}" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Users.Count, StringFormat=Найдено: {0}}" Foreground="{DynamicResource Brush.Primary}" FontWeight="SemiBold" />
                            </Border>
                            <Border Style="{StaticResource StatusPill}" Margin="0,0,8,0">
                                <TextBlock Text="{Binding StudentsCount, StringFormat=Ученики: {0}}" Foreground="{DynamicResource Brush.Info}" FontWeight="SemiBold" />
                            </Border>
                            <Border Style="{StaticResource StatusPill}" Margin="0,0,8,0">
                                <TextBlock Text="{Binding ActiveCount, StringFormat=Активные: {0}}" Foreground="{DynamicResource Brush.Success}" FontWeight="SemiBold" />
                            </Border>
                            <Border Style="{StaticResource StatusPill}">
                                <TextBlock Text="{Binding TotalCompletedTasks, StringFormat=Решений: {0}}" Foreground="{DynamicResource Brush.TextSecondary}" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource InlinePanel}" Padding="9" Margin="16,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Выбранный пользователь" Style="{StaticResource Text.Eyebrow}" />
                            <TextBlock Text="{Binding SelectedUserTitle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,3,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedUserDetails}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,3,0,6" TextWrapping="Wrap" />
                            <Button Content="{Binding ToggleBlockedButtonText}"
                                    Command="{Binding ToggleBlockedCommand}"
                                    Style="{StaticResource DangerButton}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="30"
                                    Padding="10,4"
                                    FontSize="12" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="По заданным условиям никого не найдено."
                           Style="{StaticResource Text.Body}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding HasUsers, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                <DataGrid ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          IsReadOnly="True"
                          Visibility="{Binding HasUsers, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ученик / пользователь" Binding="{Binding FullName}" Width="1.4*" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*" />
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role, Converter={StaticResource EnumDisplayConverter}}" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" />
                        <DataGridTextColumn Header="Решений" Binding="{Binding CompletedTasks}" />
                        <DataGridTextColumn Header="Тестов" Binding="{Binding TestAttemptsCount}" />
                        <DataGridTextColumn Header="Средний тест" Binding="{Binding AverageTestPercent, StringFormat={}{0:0.#}%}" />
                        <DataGridTextColumn Header="Отзывы" Binding="{Binding ReviewsCount}" />
                        <DataGridTextColumn Header="Регистрация" Binding="{Binding CreatedAtUtc, StringFormat={}{0:dd.MM.yyyy}}" />
                        <DataGridTextColumn Header="Последний вход" Binding="{Binding LastLoginAtUtc, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="1.2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="4,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Success}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Brush.Danger}" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
