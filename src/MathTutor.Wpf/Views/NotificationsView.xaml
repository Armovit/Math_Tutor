<UserControl x:Class="MathTutor.Wpf.Views.NotificationsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource SurfaceCard}"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16"><Button Content="Обновить" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Отметить прочитанным" Command="{Binding MarkAsReadCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel><DataGrid ItemsSource="{Binding Notifications}" SelectedItem="{Binding SelectedNotification}" IsReadOnly="True"><DataGrid.Columns><DataGridCheckBoxColumn Header="Прочитано" Binding="{Binding IsRead}"/><DataGridTextColumn Header="Тип" Binding="{Binding Type}"/><DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="2*"/><DataGridTextColumn Header="Дата" Binding="{Binding CreatedAtUtc}"/></DataGrid.Columns></DataGrid></DockPanel></Border>
</UserControl>

