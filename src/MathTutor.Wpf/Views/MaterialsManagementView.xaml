<UserControl x:Class="MathTutor.Wpf.Views.MaterialsManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MathTutor.Wpf.Controls">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="0.85*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource SurfaceCard}" Margin="0,0,18,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Материалы, теория и тесты" Style="{StaticResource Text.H2}" Margin="0,0,0,6" />
                    <TextBlock Text="Создавайте теорию, карточки тестов и практические материалы. Вопросы теста добавляются на экране «Задачи»." Style="{StaticResource Text.Caption}" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Поиск" Style="{StaticResource Text.Caption}" />
                        <TextBox Grid.Row="1" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,10,12" />

                        <TextBlock Grid.Column="1" Text="Тема" Style="{StaticResource Text.Caption}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TopicFilter, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,10,12" />

                        <TextBlock Grid.Column="2" Text="Раздел" Style="{StaticResource Text.Caption}" />
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SectionFilter, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                        <TextBlock Grid.Row="2" Text="Тип" Style="{StaticResource Text.Caption}" />
                        <ComboBox Grid.Row="3" ItemsSource="{Binding MaterialTypeFilters}" SelectedItem="{Binding TypeFilter}" Margin="0,6,10,0" />

                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Сложность" Style="{StaticResource Text.Caption}" />
                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding DifficultyFilters}" SelectedItem="{Binding DifficultyFilter}" Margin="0,6,10,0" />

                        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,6,0,0">
                            <CheckBox Content="Только опубликованные" IsChecked="{Binding PublishedOnlyFilter}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="4">
                        <Button Content="Найти" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                        <Button Content="Сбросить" Command="{Binding ResetFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                        <Button Content="Новый материал" Command="{Binding NewMaterialCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                        <Button Content="Новый тест" Command="{Binding NewTestMaterialCommand}" Style="{StaticResource PrimaryButton}" />
                    </UniformGrid>
                </StackPanel>

                <DataGrid ItemsSource="{Binding Materials}" SelectedItem="{Binding SelectedMaterial}" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Тема" Binding="{Binding Topic}" Width="*" />
                        <DataGridTextColumn Header="Раздел" Binding="{Binding Section}" Width="*" />
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="1.4*" />
                        <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto" />
                        <DataGridTextColumn Header="Сложность" Binding="{Binding Difficulty}" Width="Auto" />
                        <DataGridCheckBoxColumn Header="Опубликован" Binding="{Binding IsPublished}" Width="Auto" />
                        <DataGridTextColumn Header="Вопросы" Binding="{Binding TaskCount}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource SurfaceCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Редактор материала" Style="{StaticResource Text.H2}" Margin="0,0,0,6" />
                    <TextBlock Text="Для теста сначала сохраните карточку, затем добавьте к ней вопросы в разделе «Задачи»." Style="{StaticResource Text.Caption}" Margin="0,0,0,16" />

                    <Border Style="{StaticResource InlinePanel}" Visibility="{Binding IsEditingTest, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                        <TextBlock Text="Вы создаёте тест. Здесь задаются название, тема и описание. Сами вопросы теста создаются отдельно на экране «Задачи»." Style="{StaticResource Text.Body}" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Тип материала" Style="{StaticResource Text.Caption}" />
                    <ComboBox ItemsSource="{Binding MaterialTypes}" SelectedItem="{Binding EditType}" Margin="0,4,0,12" />

                    <TextBlock Text="Название" Style="{StaticResource Text.Caption}" />
                    <DockPanel Margin="0,4,0,12">
                        <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenTitleLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                        <TextBox x:Name="TitleTextBox" Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Тема" Style="{StaticResource Text.Caption}" />
                            <DockPanel Margin="0,4,0,12">
                                <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenTopicLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                                <TextBox x:Name="TopicTextBox" Text="{Binding EditTopic, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Раздел" Style="{StaticResource Text.Caption}" />
                            <DockPanel Margin="0,4,0,12">
                                <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenSectionLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                                <TextBox x:Name="SectionTextBox" Text="{Binding EditSection, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Описание" Style="{StaticResource Text.Caption}" />
                    <DockPanel Margin="0,4,0,12">
                        <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenDescriptionLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                        <TextBox x:Name="DescriptionTextBox" Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="82" TextWrapping="Wrap" />
                    </DockPanel>

                    <TextBlock Text="Содержание или инструкция" Style="{StaticResource Text.Caption}" />
                    <DockPanel Margin="0,4,0,12">
                        <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenTheoryLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                        <TextBox x:Name="TheoryTextBox" Text="{Binding EditTheory, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="150" TextWrapping="Wrap" />
                    </DockPanel>

                    <Border Style="{StaticResource InlinePanel}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Предпросмотр содержания" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                            <controls:LatexTextBlock Text="{Binding EditTheory}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="14" TextLineHeight="23" FormulaFontSize="20" MinHeight="72" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Сложность" Style="{StaticResource Text.Caption}" />
                    <ComboBox ItemsSource="{Binding DifficultyLevels}" SelectedItem="{Binding EditDifficulty}" Margin="0,4,0,12" />
                    <CheckBox Content="Опубликован" IsChecked="{Binding EditIsPublished}" Margin="0,0,0,12" />

                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Button Content="Опубликовать" Command="{Binding PublishCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                        <Button Content="Снять с публикации" Command="{Binding UnpublishCommand}" Style="{StaticResource SecondaryButton}" />
                    </UniformGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Brush.Danger}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Success}" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <Button Content="Сохранить материал" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,16,0,8" />
                    <Button Content="Удалить" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

