<Window x:Class="MathTutor.Wpf.Views.PracticeSolverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MathTutor.Wpf.Controls"
        Title="Режим решения"
        Width="1300"
        Height="820"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Background="{DynamicResource Brush.AppBackground}" Margin="18">
        <Border Style="{StaticResource ExperienceShell}" Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PremiumPanel}" Margin="0,0,22,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,18">
                            <Border Style="{StaticResource FeatureChip}" HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="Режим решения" Foreground="White" FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Выбор теста" Foreground="White" FontSize="30" FontWeight="Bold" TextWrapping="Wrap" />
                            <TextBlock Text="Можно менять тему и тест прямо здесь, не возвращаясь в каталог." Foreground="#E8FFFFFF" TextWrapping="Wrap" Margin="0,10,0,16" />

                            <TextBlock Text="Тема" Foreground="#CCFFFFFF" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}" DisplayMemberPath="Name" Margin="0,0,0,12" />

                            <TextBlock Text="Тест" Foreground="#CCFFFFFF" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding SelectedTopic.Tests}" SelectedItem="{Binding SelectedMaterial}" DisplayMemberPath="Title" Margin="0,0,0,16" />

                            <Border Style="{StaticResource FeatureChip}" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding SelectedMaterial.Section}" Foreground="White" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource FloatingActionPanel}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Прогресс" Style="{StaticResource Text.Eyebrow}" />
                                    <TextBlock Text="{Binding QuestionProgressText}" FontSize="22" FontWeight="Bold" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding TestMaxScore, StringFormat=Максимум: {0} баллов}" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource FloatingActionPanel}" Padding="12">
                                <ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" DisplayMemberPath="Title" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource FocusCard}" Margin="0,0,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource AccentStrip}" Margin="0,0,24,0" />
                                <StackPanel Grid.Column="1">
                                    <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Margin="0,0,0,14">
                                        <TextBlock Text="{Binding QuestionProgressText}" Foreground="{DynamicResource Brush.Primary}" FontWeight="Bold" />
                                    </Border>
                                    <TextBlock Text="{Binding CurrentTask.Title}" FontSize="34" FontWeight="Bold" TextWrapping="Wrap" />
                                    <controls:LatexTextBlock Text="{Binding CurrentTask.Question}" FontSize="19" TextLineHeight="31" FormulaFontSize="25" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,14,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SurfaceCard}" Visibility="{Binding IsPracticeMode, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Ваше решение" Style="{StaticResource Text.H2}" Margin="0,0,0,12" />
                                <DockPanel Margin="0,0,0,14">
                                    <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenPracticeLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                                    <TextBox x:Name="PracticeAnswerTextBox" Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="110" VerticalContentAlignment="Top" />
                                </DockPanel>
                                <Button Content="Отправить решение" Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCard}" Visibility="{Binding IsSelectedMaterialTest, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Тестовый режим" Style="{StaticResource Text.Eyebrow}" />
                                        <TextBlock Text="Решайте спокойно, по одному вопросу" Style="{StaticResource Text.H2}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Начать тест" Command="{Binding StartTestCommand}" Style="{StaticResource PrimaryButton}" Visibility="{Binding CanStartTest, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>

                                <StackPanel Visibility="{Binding TestStarted, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DockPanel Visibility="{Binding IsTextAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                        <Button DockPanel.Dock="Right" Content="LaTeX" Click="OpenTestLatex_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                                        <TextBox x:Name="TestAnswerTextBox" Text="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="110" VerticalContentAlignment="Top" />
                                    </DockPanel>

                                    <ListBox ItemsSource="{Binding AnswerOptions}" SelectedItem="{Binding SelectedAnswerOption}" Visibility="{Binding IsSingleChoiceAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,16">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TestCard}" Margin="0,0,0,8" HorizontalAlignment="Stretch" ClipToBounds="True">
                                                    <controls:LatexTextBlock Text="{Binding Text}" FontSize="16" TextLineHeight="24" FormulaFontSize="21" Foreground="{DynamicResource Brush.TextPrimary}" />
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <ItemsControl ItemsSource="{Binding AnswerOptions}" Visibility="{Binding IsMultipleChoiceAnswer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,16">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TestCard}" Margin="0,0,0,8">
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="16">
                                                        <controls:LatexTextBlock Text="{Binding Text}" FontSize="16" TextLineHeight="24" FormulaFontSize="21" Foreground="{DynamicResource Brush.TextPrimary}" />
                                                    </CheckBox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Style="{StaticResource FloatingActionPanel}" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Назад" Command="{Binding PreviousQuestionCommand}" Style="{StaticResource SecondaryButton}" IsEnabled="{Binding CanGoPrevious}" />
                                            <Button Content="Далее" Command="{Binding NextQuestionCommand}" Style="{StaticResource SecondaryButton}" IsEnabled="{Binding CanGoNext}" Margin="8,0,0,0" />
                                            <Button Content="Завершить тест" Command="{Binding FinishTestCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Success}" Margin="4,14,0,0" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Brush.Danger}" Margin="4,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
