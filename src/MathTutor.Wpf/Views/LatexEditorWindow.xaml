<Window x:Class="MathTutor.Wpf.Views.LatexEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MathTutor.Wpf.Controls"
        Title="LaTeX-формула"
        Width="760"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PremiumPanel}" Margin="0,0,0,18">
            <StackPanel>
                <Border Style="{StaticResource FeatureChip}" HorizontalAlignment="Left" Margin="0,0,0,12">
                    <TextBlock Text="LaTeX helper" Foreground="White" FontWeight="Bold" />
                </Border>
                <TextBlock Text="Редактор формулы" Foreground="White" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Выберите шаблон или напишите формулу вручную. Она будет вставлена в активное поле как LaTeX-текст." Foreground="#E8FFFFFF" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource GlowCard}" Margin="0,0,18,0">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Шаблоны" Style="{StaticResource Text.H3}" Margin="0,0,0,12" />
                        <Button Content="Дробь: \frac{a}{b}" Tag="\frac{a}{b}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Степень: x^{2}" Tag="x^{2}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Индекс: a_{n}" Tag="a_{n}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Корень: \sqrt{x}" Tag="\sqrt{x}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Корень n: \sqrt[n]{x}" Tag="\sqrt[n]{x}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Квадратное: ax^{2}+bx+c=0" Tag="ax^{2}+bx+c=0" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Интервал: x \in [a;b]" Tag="x \in [a;b]" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Неравенство: x \leq y" Tag="x \leq y" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Система уравнений" Tag="\begin{cases} x+y=0 \\ x-y=2 \end{cases}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Предел: \lim_{x\to a}" Tag="\lim_{x\to a}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Сумма: \sum_{i=1}^{n}" Tag="\sum_{i=1}^{n}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                        <Button Content="Интеграл: \int_{a}^{b}" Tag="\int_{a}^{b}" Click="InsertTemplate_Click" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SurfaceCard}">
                <StackPanel>
                    <TextBlock Text="Формула" Style="{StaticResource Text.H3}" />
                    <TextBox x:Name="FormulaTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="170"
                             VerticalContentAlignment="Top"
                             Margin="0,8,0,14" />

                    <TextBlock Text="Предпросмотр" Style="{StaticResource Text.Caption}" />
                    <Border Style="{StaticResource InlinePanel}" Margin="0,6,0,14">
                        <controls:LatexTextBlock Text="{Binding Text, ElementName=FormulaTextBox, StringFormat=\({0}\)}"
                                                 FontSize="18"
                                                 TextLineHeight="28"
                                                 FormulaFontSize="26"
                                                 Foreground="{DynamicResource Brush.TextPrimary}" />
                    </Border>

                    <TextBlock Text="Подсказка: для формул в тексте используйте \( ... \), а для отдельной строки можно использовать \[ ... \]." Style="{StaticResource Text.Caption}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Отмена" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
            <Button Content="Вставить формулу" Click="Insert_Click" Style="{StaticResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Window>
