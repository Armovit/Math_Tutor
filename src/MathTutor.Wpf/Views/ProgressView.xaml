<UserControl x:Class="MathTutor.Wpf.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel>
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Экспорт в Excel" Command="{Binding ExportProgressCommand}" Style="{StaticResource PrimaryButton}" />
                <Button DockPanel.Dock="Right" Content="Обновить" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                <TextBlock Text="Прогресс и история" Style="{StaticResource Text.H2}" VerticalAlignment="Center" />
            </DockPanel>

            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Выполнено заданий" Style="{StaticResource Text.Caption}" /><TextBlock Text="{Binding Progress.CompletedTasks}" Style="{StaticResource Text.H1}" /></StackPanel></Border>
                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Средний результат" Style="{StaticResource Text.Caption}" /><TextBlock Text="{Binding Progress.AverageScore, StringFormat={}{0}%}" Style="{StaticResource Text.H1}" /></StackPanel></Border>
                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Средний тест" Style="{StaticResource Text.Caption}" /><TextBlock Text="{Binding Progress.AverageTestPercent, StringFormat={}{0}%}" Style="{StaticResource Text.H1}" /></StackPanel></Border>
                <Border Style="{StaticResource SurfaceCard}"><StackPanel><TextBlock Text="Лучший тест" Style="{StaticResource Text.Caption}" /><TextBlock Text="{Binding Progress.BestTestPercent, StringFormat={}{0}%}" Style="{StaticResource Text.H1}" /></StackPanel></Border>
            </UniformGrid>

            <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Прогресс по темам" Style="{StaticResource Text.H2}" Margin="0,0,0,16" />
                    <ItemsControl ItemsSource="{Binding Progress.TopicProgress}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Topic}" Style="{StaticResource Text.Body}" />
                                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding AveragePercent}" Height="12" Margin="12,4" />
                                    <TextBlock Grid.Column="2" Text="{Binding AveragePercent, StringFormat={}{0}%}" Style="{StaticResource Text.Caption}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Рекомендации" Style="{StaticResource Text.H2}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Progress.Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InlinePanel}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Topic}" Style="{StaticResource Text.H3}" />
                                        <TextBlock Text="{Binding Message}" Style="{StaticResource Text.Body}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="История тестов" Style="{StaticResource Text.H2}" Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ComboBox ItemsSource="{Binding AttemptTopics}" SelectedItem="{Binding SelectedAttemptTopic}" Width="180" />
                        <ComboBox ItemsSource="{Binding TestMaterials}" SelectedItem="{Binding SelectedAttemptMaterial}" DisplayMemberPath="Title" Width="260" Margin="8,0,0,0" />
                        <Button Content="Применить" Command="{Binding ApplyAttemptFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                        <Button Content="Сбросить" Command="{Binding ResetAttemptFiltersCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Attempts}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тема" Binding="{Binding MaterialTitle}" Width="*" />
                            <DataGridTextColumn Header="Раздел" Binding="{Binding MaterialSection}" Width="*" />
                            <DataGridTextColumn Header="Балл" Binding="{Binding Score}" />
                            <DataGridTextColumn Header="Максимум" Binding="{Binding MaxScore}" />
                            <DataGridTextColumn Header="Процент" Binding="{Binding Percent, StringFormat={}{0}%}" />
                            <DataGridTextColumn Header="Оценка (из 10)" Binding="{Binding Grade}" />
                            <DataGridTextColumn Header="Дата" Binding="{Binding CompletedAtUtc}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCard}">
                <StackPanel>
                    <TextBlock Text="Последние ответы" Style="{StaticResource Text.H2}" Margin="0,0,0,16" />
                    <DataGrid ItemsSource="{Binding Progress.RecentSubmissions}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Задание" Binding="{Binding TaskTitle}" Width="*" />
                            <DataGridTextColumn Header="Ответ" Binding="{Binding Answer}" />
                            <DataGridTextColumn Header="Балл" Binding="{Binding Score}" />
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Feedback}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
