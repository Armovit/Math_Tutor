<UserControl x:Class="MathTutor.Wpf.Views.AdminDashboardView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel>
            <Border Style="{StaticResource PremiumPanel}" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Администрирование" Foreground="#DFFFFFFF" FontWeight="Bold" FontSize="12" />
                    <TextBlock Text="Пульс образовательной системы" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,4,0,0" />
                    <TextBlock Text="Статистика пользователей, материалов, решений и среднего результата в одном месте." Foreground="#E8FFFFFF" FontSize="15" TextWrapping="Wrap" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Ученики" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.StudentsCount}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Материалы" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.MaterialsCount}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Решения" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.SubmissionsCount}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="Средний результат" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.AverageScore, StringFormat={}{0}%}" Style="{StaticResource Text.H1}"/></StackPanel></Border>
            </UniformGrid>
            <Border Style="{StaticResource GlowCard}"><StackPanel><TextBlock Text="Успеваемость учеников" Style="{StaticResource Text.H2}" Margin="0,0,0,16"/><DataGrid ItemsSource="{Binding Statistics.Students}"><DataGrid.Columns><DataGridTextColumn Header="Ученик" Binding="{Binding FullName}" Width="*"/><DataGridTextColumn Header="Выполнено" Binding="{Binding CompletedTasks}"/><DataGridTextColumn Header="Средний балл" Binding="{Binding AverageScore}"/><DataGridTextColumn Header="Прогресс" Binding="{Binding CompletionPercent}"/></DataGrid.Columns></DataGrid></StackPanel></Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

