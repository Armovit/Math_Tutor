<UserControl x:Class="MathTutor.Wpf.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:MathTutor.Wpf.Behaviors">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid MaxWidth="1200" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" MinWidth="360" />
                <ColumnDefinition Width="0.95*" MinWidth="420" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource PremiumPanel}" VerticalAlignment="Center" Margin="24" Padding="38">
                <StackPanel>
                    <Border Background="#26FFFFFF" CornerRadius="999" Padding="12,7" HorizontalAlignment="Left" Margin="0,0,0,18">
                        <TextBlock Text="Профессиональная подготовка" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                    </Border>
                    <TextBlock Text="Математика в формате premium dashboard" Foreground="White" FontSize="44" FontWeight="Bold" TextWrapping="Wrap" LineHeight="50" />
                    <TextBlock Text="Темы, тесты, автоматическая проверка, баллы, прогресс и статистика в интерфейсе уровня современного educational SaaS." Foreground="#E8FFFFFF" FontSize="16" TextWrapping="Wrap" Margin="0,18,0,0" LineHeight="24" />
                    <Grid Margin="0,28,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#18FFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Тематические тесты" Foreground="White" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="Вкладки тем, несколько тестов и подробный итог." Foreground="#DFFFFFFF" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#18FFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1" CornerRadius="20" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Живой прогресс" Foreground="White" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="Баллы, проценты, попытки и статистика ученика." Foreground="#DFFFFFFF" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <UniformGrid Columns="3" Margin="0,30,0,0">
                        <Border Background="#24FFFFFF" CornerRadius="18" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="10+" Foreground="White" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="заданий в тесте" Foreground="#E8FFFFFF" FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Border Background="#24FFFFFF" CornerRadius="18" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="100%" Foreground="White" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="автопроверка" Foreground="#E8FFFFFF" FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Border Background="#24FFFFFF" CornerRadius="18" Padding="14">
                            <StackPanel>
                                <TextBlock Text="24/7" Foreground="White" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="прогресс" Foreground="#E8FFFFFF" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource GlowCard}" MaxWidth="480" MinWidth="400" VerticalAlignment="Center" Margin="24">
                <StackPanel>
                    <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Margin="0,0,0,14">
                        <TextBlock Text="Добро пожаловать" Foreground="{DynamicResource Brush.Primary}" FontWeight="Bold" />
                    </Border>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource Text.H1}" />
                    <TextBlock Text="Войдите как администратор или зарегистрируйте ученика." Style="{StaticResource Text.Body}" Margin="0,8,0,20" />
                <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Имя" Style="{StaticResource Text.Caption}"/><TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                    <TextBlock Text="Фамилия" Style="{StaticResource Text.Caption}"/><TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                </StackPanel>
                <TextBlock Text="Email" Style="{StaticResource Text.Caption}"/><TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                <TextBlock Text="Пароль" Style="{StaticResource Text.Caption}"/>
                <Grid Margin="0,4,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="44" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox b:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <TextBox Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Grid.Column="1"
                            Content="👁"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="8,0,0,0"
                            ToolTip="Показать или скрыть пароль" />
                </Grid>
                <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Подтверждение пароля" Style="{StaticResource Text.Caption}"/>
                    <Grid Margin="0,4,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox b:PasswordBoxAssistant.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsConfirmPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Grid.Column="1"
                                Content="👁"
                                Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                Style="{StaticResource IconButton}"
                                Margin="8,0,0,0"
                                ToolTip="Показать или скрыть подтверждение пароля" />
                    </Grid>
                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Brush.Danger}" Style="{StaticResource Text.Body}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Brush.Success}" Style="{StaticResource Text.Body}" Margin="0,0,0,8" />
                <Button Content="Продолжить" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButton}" />
                    <Button Content="Переключить вход / регистрацию" Command="{Binding ToggleModeCommand}" Style="{StaticResource SecondaryButton}" Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

