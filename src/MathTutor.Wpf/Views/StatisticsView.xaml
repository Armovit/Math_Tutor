<UserControl x:Class="MathTutor.Wpf.Views.StatisticsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel><StackPanel Orientation="Horizontal" Margin="0,0,0,16"><Button Content="Обновить" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Экспорт в Excel" Command="{Binding ExportStatisticsCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel><UniformGrid Columns="4" Margin="0,0,0,24"><Border Style="{StaticResource SurfaceCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Ученики" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.StudentsCount}" Style="{StaticResource Text.H1}"/></StackPanel></Border><Border Style="{StaticResource SurfaceCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Опубликовано" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.PublishedMaterialsCount}" Style="{StaticResource Text.H1}"/></StackPanel></Border><Border Style="{StaticResource SurfaceCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Решения" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.SubmissionsCount}" Style="{StaticResource Text.H1}"/></StackPanel></Border><Border Style="{StaticResource SurfaceCard}"><StackPanel><TextBlock Text="Средний балл" Style="{StaticResource Text.Caption}"/><TextBlock Text="{Binding Statistics.AverageScore, StringFormat={}{0}%}" Style="{StaticResource Text.H1}"/></StackPanel></Border></UniformGrid><Border Style="{StaticResource SurfaceCard}"><DataGrid ItemsSource="{Binding Statistics.Students}" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Ученик" Binding="{Binding FullName}" Width="*"/><DataGridTextColumn Header="Выполнено" Binding="{Binding CompletedTasks}"/><DataGridTextColumn Header="Средний" Binding="{Binding AverageScore}"/><DataGridTextColumn Header="Прогресс" Binding="{Binding CompletionPercent}"/></DataGrid.Columns></DataGrid></Border><TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Brush.Success}" Margin="4,12,0,0"/></StackPanel></ScrollViewer>
</UserControl>

