<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Background">#FF080C16</Color>
    <Color x:Key="Color.BackgroundSoft">#FF121A2B</Color>
    <Color x:Key="Color.Surface">#FF101624</Color>
    <Color x:Key="Color.SurfaceAlt">#FF172033</Color>
    <Color x:Key="Color.SurfaceHover">#FF202B42</Color>
    <Color x:Key="Color.Border">#FF273349</Color>
    <Color x:Key="Color.BorderStrong">#FF3A4A68</Color>
    <Color x:Key="Color.TextPrimary">#FFF7FAFF</Color>
    <Color x:Key="Color.TextSecondary">#FFD4DEEF</Color>
    <Color x:Key="Color.TextMuted">#FF95A3B8</Color>
    <Color x:Key="Color.Primary">#FF8B9CFF</Color>
    <Color x:Key="Color.PrimaryHover">#FFA7B4FF</Color>
    <Color x:Key="Color.PrimaryPressed">#FF6475F7</Color>
    <Color x:Key="Color.PrimarySoft">#FF1E2752</Color>
    <Color x:Key="Color.Accent">#FF2DD4BF</Color>
    <Color x:Key="Color.AccentSoft">#FF123A3A</Color>
    <Color x:Key="Color.Success">#FF34D399</Color>
    <Color x:Key="Color.SuccessSoft">#FF12392E</Color>
    <Color x:Key="Color.Warning">#FFFBBF24</Color>
    <Color x:Key="Color.WarningSoft">#FF3C2F12</Color>
    <Color x:Key="Color.Danger">#FFF87171</Color>
    <Color x:Key="Color.DangerSoft">#FF3B1519</Color>
    <Color x:Key="Color.Info">#FF38BDF8</Color>
    <Color x:Key="Color.DifficultyBeginner">#FF34D399</Color>
    <Color x:Key="Color.DifficultyIntermediate">#FFFBBF24</Color>
    <Color x:Key="Color.DifficultyAdvanced">#FFF87171</Color>

    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.BackgroundSoft" Color="{StaticResource Color.BackgroundSoft}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{StaticResource Color.SurfaceHover}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.PrimaryHover" Color="{StaticResource Color.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.PrimaryPressed" Color="{StaticResource Color.PrimaryPressed}" />
    <SolidColorBrush x:Key="Brush.PrimarySoft" Color="{StaticResource Color.PrimarySoft}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="{StaticResource Color.AccentSoft}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessSoft" Color="{StaticResource Color.SuccessSoft}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.WarningSoft" Color="{StaticResource Color.WarningSoft}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />
    <SolidColorBrush x:Key="Brush.DangerSoft" Color="{StaticResource Color.DangerSoft}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}" />

    <LinearGradientBrush x:Key="Brush.AppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF050914" Offset="0" />
        <GradientStop Color="#FF0C1424" Offset="0.48" />
        <GradientStop Color="#FF14213F" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7C3AED" Offset="0" />
        <GradientStop Color="#FF4F46E5" Offset="0.5" />
        <GradientStop Color="#FF0891B2" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.PremiumGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF111827" Offset="0" />
        <GradientStop Color="#FF3730A3" Offset="0.48" />
        <GradientStop Color="#FF0E7490" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.SuccessGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF047857" Offset="0" />
        <GradientStop Color="#FF059669" Offset="0.58" />
        <GradientStop Color="#FF0891B2" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.WarmGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFEA580C" Offset="0" />
        <GradientStop Color="#FFD97706" Offset="0.55" />
        <GradientStop Color="#FFF59E0B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.SidebarGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0B1020" Offset="0" />
        <GradientStop Color="#FF101827" Offset="0.58" />
        <GradientStop Color="#FF111D38" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
