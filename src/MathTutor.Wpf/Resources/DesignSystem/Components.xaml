<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="SurfaceCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="26" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.10" Color="#0F172A" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.PrimaryGradient}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="Padding" Value="32" />
    </Style>

    <Style x:Key="GlassCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    </Style>

    <Style x:Key="PremiumPanel" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.PremiumGradient}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="Padding" Value="34" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="36" ShadowDepth="12" Opacity="0.18" Color="#312E81" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Padding" Value="22" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    </Style>

    <Style x:Key="GlowCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="34" ShadowDepth="10" Opacity="0.14" Color="#4F46E5" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentStrip" TargetType="Border">
        <Setter Property="Width" Value="5" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="{DynamicResource Brush.PrimaryGradient}" />
    </Style>

    <Style x:Key="FeatureChip" TargetType="Border">
        <Setter Property="Background" Value="#1FFFFFFF" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="12,7" />
    </Style>

    <Style x:Key="SidebarUserCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.BackgroundSoft}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style x:Key="InlinePanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="ResultCard" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.BackgroundSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    </Style>

    <Style x:Key="CatalogSectionHeader" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.BackgroundSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="CatalogTopicItem" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="TestCard" TargetType="Border" BasedOn="{StaticResource InlinePanel}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.08" Color="#4F46E5" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CatalogTestCard" TargetType="Border" BasedOn="{StaticResource TestCard}">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="ExperienceShell" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="44" ShadowDepth="12" Opacity="0.16" Color="#1E3A8A" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ReadingPaper" TargetType="Border" BasedOn="{StaticResource SurfaceCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="42" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.09" Color="#7C2D12" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FocusCard" TargetType="Border" BasedOn="{StaticResource GlowCard}">
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="Padding" Value="34" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
    </Style>

    <Style x:Key="FloatingActionPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.12" Color="#4F46E5" />
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

