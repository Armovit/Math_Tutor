<Application x:Class="MathTutor.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MathTutor.Wpf.Converters"
             xmlns:vm="clr-namespace:MathTutor.Wpf.ViewModels"
             xmlns:views="clr-namespace:MathTutor.Wpf.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DesignSystem/Themes/LightTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <conv:EnumDisplayConverter x:Key="EnumDisplayConverter" />
            <DataTemplate DataType="{x:Type vm:LoginViewModel}"><views:LoginView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:AdminDashboardViewModel}"><views:AdminDashboardView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:StudentDashboardViewModel}"><views:StudentDashboardView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:MaterialsManagementViewModel}"><views:MaterialsManagementView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:TaskManagementViewModel}"><views:TaskManagementView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:StudentMaterialsViewModel}"><views:StudentMaterialsView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:TheoryViewModel}"><views:TheoryView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProgressViewModel}"><views:ProgressView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReviewsViewModel}"><views:ReviewsView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:NotificationsViewModel}"><views:NotificationsView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:UsersViewModel}"><views:UsersView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:StatisticsViewModel}"><views:StatisticsView /></DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>

